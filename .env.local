## Backend base URL used by the frontend for API calls.
## Example: http://localhost:8000
VITE_API_BASE_URL=

## Optional: product name shown on the landing page.
VITE_PRODUCT_NAME=

# Preview mode: use hardcoded dummy data and mock upload/report calls.
# Set to `false` to use your real backend.
VITE_USE_DUMMY_DATA=true

